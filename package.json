{
  "name": "jobscout",
  "private": true,
  "version": "0.1.0",
  "description": "Germany-focused job aggregation and recommendation app.",
  "workspaces": [
    "web",
    "worker",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "worker:dev": "npm run dev --workspace worker"
  },
  "engines": {
    "node": ">=20"
  }
}
