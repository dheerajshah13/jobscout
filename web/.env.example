NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only secret — used by /api/account/export and account deletion.
# Never prefix this with NEXT_PUBLIC_ or it will be shipped to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only secret — used to parse uploaded resumes into profile fields.
# Without it, resume upload still works but falls back to free offline
# keyword extraction (see web/lib/resume.ts).
ANTHROPIC_API_KEY=

# Server-only aggregator keys — enable live results on /discover and richer
# AI-matching runs. Each is optional; the app degrades gracefully without them.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
JSEARCH_API_KEY=
